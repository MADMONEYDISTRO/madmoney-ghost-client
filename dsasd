-- Modernized Button Creation Helper
local function createButton(parent, text, position, size)
    local buttonContainer = Instance.new("Frame")
    buttonContainer.Size = size or UDim2.new(0.9, 0, 0, 42)
    buttonContainer.Position = position or UDim2.new(0.05, 0, 0, 0)
    buttonContainer.BackgroundTransparency = 1
    buttonContainer.ZIndex = 2
    
    local button = Instance.new("TextButton")
    button.Name = text .. "Button"
    button.Size = UDim2.new(1, 0, 1, 0)
    button.Text = ""
    button.BackgroundColor3 = colors.buttonBg
    button.AutoButtonColor = false
    button.BorderSizePixel = 0
    button.ZIndex = 2
    button.Parent = buttonContainer
    
    -- Modern gradient overlay
    local btnGradient = Instance.new("UIGradient")
    btnGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
    }
    btnGradient.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 0.95),
        NumberSequenceKeypoint.new(1, 0.98)
    }
    btnGradient.Rotation = 90
    btnGradient.Parent = button
    
    Instance.new("UICorner", button).CornerRadius = UDim.new(0, 8)
    
    -- Icon background
    local iconBg = Instance.new("Frame")
    iconBg.Size = UDim2.new(0, 32, 0, 32)
    iconBg.Position = UDim2.new(0, 8, 0.5, -16)
    iconBg.BackgroundColor3 = colors.accent
    iconBg.BackgroundTransparency = 0.9
    iconBg.BorderSizePixel = 0
    iconBg.ZIndex = 3
    iconBg.Parent = button
    
    Instance.new("UICorner", iconBg).CornerRadius = UDim.new(0, 6)
    
    -- Icon
    local icon = Instance.new("TextLabel")
    icon.Size = UDim2.new(1, 0, 1, 0)
    icon.Text = ""
    icon.Font = Enum.Font.GothamBold
    icon.TextSize = 14
    icon.TextColor3 = colors.accent
    icon.BackgroundTransparency = 1
    icon.ZIndex = 4
    icon.Parent = iconBg
    
    -- Text
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -50, 1, 0)
    textLabel.Position = UDim2.new(0, 48, 0, 0)
    textLabel.Text = text
    textLabel.Font = Enum.Font.GothamSemibold
    textLabel.TextSize = 13
    textLabel.TextColor3 = colors.text
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.BackgroundTransparency = 1
    textLabel.ZIndex = 3
    textLabel.Parent = button
    
    -- Hover effects
    button.MouseEnter:Connect(function()
        if settings.animations then
            TweenService:Create(button, getAnimInfo(), {
                BackgroundColor3 = colors.buttonHover
            }):Play()
            TweenService:Create(iconBg, getAnimInfo(), {
                BackgroundTransparency = 0.8,
                Size = UDim2.new(0, 34, 0, 34)
            }):Play()
        end
    end)
    
    button.MouseLeave:Connect(function()
        if settings.animations then
            TweenService:Create(button, getAnimInfo(), {
                BackgroundColor3 = colors.buttonBg
            }):Play()
            TweenService:Create(iconBg, getAnimInfo(), {
                BackgroundTransparency = 0.9,
                Size = UDim2.new(0, 32, 0, 32)
            }):Play()
        end
    end)
    
    buttonContainer.Parent = parent
    return button, icon, textLabel
end

