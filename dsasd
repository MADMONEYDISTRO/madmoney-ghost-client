        animTitle.Font = Enum.Font.GothamSemibold
        animTitle.TextSize = 13
        animTitle.TextColor3 = colors.text
        animTitle.TextXAlignment = Enum.TextXAlignment.Left
        animTitle.BackgroundTransparency = 1
        animTitle.Parent = animStyleFrame
        
        local animDesc = Instance.new("TextLabel")
        animDesc.Size = UDim2.new(1, -120, 0, 16)
        animDesc.Position = UDim2.new(0, 12, 0, 30)
        animDesc.Text = "Choose UI animation behavior"
        animDesc.Font = Enum.Font.Gotham
        animDesc.TextSize = 10
        animDesc.TextColor3 = colors.text
        animDesc.TextTransparency = 0.5
        animDesc.TextXAlignment = Enum.TextXAlignment.Left
        animDesc.BackgroundTransparency = 1
        animDesc.Parent = animStyleFrame
        
        local animDropdown = Instance.new("TextButton")
        animDropdown.Size = UDim2.new(0, 100, 0, 30)
        animDropdown.Position = UDim2.new(1, -110, 0, 12)
        animDropdown.Text = settings.animationStyle
        animDropdown.Font = Enum.Font.GothamMedium
        animDropdown.TextSize = 11
        animDropdown.TextColor3 = colors.text
        animDropdown.BackgroundColor3 = colors.buttonBg
        animDropdown.BorderSizePixel = 0
        animDropdown.AutoButtonColor = false
        animDropdown.Parent = animStyleFrame
        
        Instance.new("UICorner", animDropdown).CornerRadius = UDim.new(0, 6)
        
        local currentStyleIndex = 1
        local styleNames = {"Smooth", "Bounce", "Elastic", "Quick"}
        
        for i, name in ipairs(styleNames) do
            if name == settings.animationStyle then
                currentStyleIndex = i
                break
            end
        end
        
        animDropdown.MouseButton1Click:Connect(function()
            currentStyleIndex = (currentStyleIndex % #styleNames) + 1
            settings.animationStyle = styleNames[currentStyleIndex]
            animDropdown.Text = settings.animationStyle
            sendNotification("Animation Style", "Changed to " .. settings.animationStyle, "ūüé¨")
        end)
        
        -- Settings Options
        createToggle("Notifications", "Show in-game notifications", settings.notifications, function(state)
            settings.notifications = state
            if state then
                sendNotification("Settings", "Notifications enabled", "")
            end
        end)
        
        createToggle("UI Animations", "Enable smooth UI transitions", settings.animations, function(state)
            settings.animations = state
            sendNotification("Settings", "Animations " .. (state and "enabled" or "disabled"), "")
        end)
        
        createToggle("Auto-Save Config", "Automatically save settings", settings.autoSave, function(state)
            settings.autoSave = state
            sendNotification("Settings", "Auto-save " .. (state and "enabled" or "disabled"), "")
        end)
        
        createToggle("FPS Unlocker", "Unlock frame rate limit", fpsUnlockerEnabled, function(state)
            fpsUnlockerEnabled = state
            if state then
                setFPSCap(999)
            else
                setFPSCap(60)
            end
        end)
        
        createToggle("Low Graphics Mode", "Reduce graphics quality", lowGfxEnabled, function(state)
            lowGfxEnabled = state
            toggleLowGFX()
        end)
        
        createToggle("Anti-AFK", "Prevent auto-kick from idling", false, function(state)
            if state then
                local VirtualUser = game:GetService("VirtualUser")
                player.Idled:Connect(function()
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton2(Vector2.new())
                end)
                sendNotification("Anti-AFK", "Protection enabled", "")
            end
        end)
        
    -- Themes Tab
    elseif tab.Name == "Themes" then
        local scrollFrame = Instance.new("ScrollingFrame")
        scrollFrame.Size = UDim2.new(1, -16, 1, -16)
        scrollFrame.Position = UDim2.new(0, 8, 0, 8)
        scrollFrame.BackgroundTransparency = 1
        scrollFrame.ScrollBarThickness = 4
        scrollFrame.ScrollBarImageColor3 = colors.accent
        scrollFrame.BorderSizePixel = 0
        scrollFrame.Parent = contentContainer
        
        local themesLayout = Instance.new("UIListLayout")
        themesLayout.Padding = UDim.new(0, 10)
        themesLayout.Parent = scrollFrame
        
        themesLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scrollFrame.CanvasSize = UDim2.new(0, 0, 0, themesLayout.AbsoluteContentSize.Y + 16)
        end)
        
        -- Title
        local themeTitle = Instance.new("TextLabel")
        themeTitle.Size = UDim2.new(1, 0, 0, 30)
        themeTitle.Text = "Theme Gallery"
        themeTitle.Font = Enum.Font.GothamBold
        themeTitle.TextSize = 16
        themeTitle.TextColor3 = colors.text
        themeTitle.TextXAlignment = Enum.TextXAlignment.Left
        themeTitle.BackgroundTransparency = 1
        themeTitle.Parent = scrollFrame
        
        local themeDesc = Instance.new("TextLabel")
        themeDesc.Size = UDim2.new(1, 0, 0, 20)
        themeDesc.Text = "Customize your UI appearance with live previews"
        themeDesc.Font = Enum.Font.Gotham
        themeDesc.TextSize = 11
        themeDesc.TextColor3 = colors.text
        themeDesc.TextTransparency = 0.5
        themeDesc.TextXAlignment = Enum.TextXAlignment.Left
        themeDesc.BackgroundTransparency = 1
        themeDesc.Parent = scrollFrame
        
        -- Theme Cards with Previews
        local themeInfo = {
            {Name = "Dark", Desc = "Classic dark mode", Icon = "ūüĆô"},
            {Name = "Light", Desc = "Clean light theme", Icon = "‚ėÄÔłŹ"},
            {Name = "MidnightBlue", Desc = "Deep ocean blue", Icon = "ūüĆä"},
            {Name = "Cyberpunk", Desc = "Neon pink vibes", Icon = "ūüíú"},
            {Name = "ForestGreen", Desc = "Nature inspired", Icon = "ūüĆ≤"},
            {Name = "SunsetOrange", Desc = "Warm and cozy", Icon = "ūüĆÖ"},
            {Name = "DeepPurple", Desc = "Royal purple", Icon = "ūüĎĎ"}
        }
        
        for _, theme in ipairs(themeInfo) do
            local themeCard = Instance.new("Frame")
            themeCard.Size = UDim2.new(1, 0, 0, 160)
            themeCard.BackgroundColor3 = colors.statsBg
            themeCard.BorderSizePixel = 0
            themeCard.Parent = scrollFrame
            
            Instance.new("UICorner", themeCard).CornerRadius = UDim.new(0, 8)
            
            -- Theme Preview
            local previewContainer = Instance.new("Frame")
            previewContainer.Size = UDim2.new(1, -20, 0, 80)
            previewContainer.Position = UDim2.new(0, 10, 0, 10)
            previewContainer.BackgroundTransparency = 1
            previewContainer.Parent = themeCard
            
            createThemePreview(theme.Name, previewContainer)
            
            -- Theme Info Row
            local infoRow = Instance.new("Frame")
            infoRow.Size = UDim2.new(1, -20, 0, 50)
            infoRow.Position = UDim2.new(0, 10, 0, 100)
            infoRow.BackgroundTransparency = 1
            infoRow.Parent = themeCard
            
            -- Icon
            local iconLabel = Instance.new("TextLabel")
            iconLabel.Size = UDim2.new(0, 40, 0, 40)
            iconLabel.Position = UDim2.new(0, 5, 0, 5)
            iconLabel.Text = theme.Icon
            iconLabel.TextSize = 28
            iconLabel.BackgroundTransparency = 1
            iconLabel.Parent = infoRow
            
            -- Theme Info
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -135, 0, 22)
            nameLabel.Position = UDim2.new(0, 50, 0, 8)
            nameLabel.Text = theme.Name
            nameLabel.Font = Enum.Font.GothamSemibold
            nameLabel.TextSize = 14
            nameLabel.TextColor3 = colors.text
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.BackgroundTransparency = 1
            nameLabel.Parent = infoRow
            
            local descLabel = Instance.new("TextLabel")
            descLabel.Size = UDim2.new(1, -135, 0, 16)
            descLabel.Position = UDim2.new(0, 50, 0, 28)
            descLabel.Text = theme.Desc
            descLabel.Font = Enum.Font.Gotham
            descLabel.TextSize = 11
            descLabel.TextColor3 = colors.text
            descLabel.TextTransparency = 0.5
            descLabel.TextXAlignment = Enum.TextXAlignment.Left
            descLabel.BackgroundTransparency = 1
            descLabel.Parent = infoRow
            
            -- Apply Button
            local applyBtn = Instance.new("TextButton")
            applyBtn.Size = UDim2.new(0, 70, 0, 36)
            applyBtn.Position = UDim2.new(1, -75, 0, 7)
            applyBtn.Text = currentTheme == theme.Name and "‚úď Active" or "Apply"
            applyBtn.Font = Enum.Font.GothamSemibold
            applyBtn.TextSize = 12
            applyBtn.TextColor3 = Color3.new(1, 1, 1)
            applyBtn.BackgroundColor3 = currentTheme == theme.Name and Color3.fromRGB(46, 204, 113) or colorSchemes[theme.Name].accent
            applyBtn.BorderSizePixel = 0
            applyBtn.AutoButtonColor = false
            applyBtn.Parent = infoRow
            
            Instance.new("UICorner", applyBtn).CornerRadius = UDim.new(0, 6)
            
            applyBtn.MouseEnter:Connect(function()
                if currentTheme ~= theme.Name then
                    TweenService:Create(applyBtn, getAnimInfo(), {
                        Size = UDim2.new(0, 75, 0, 38)
                    }):Play()
                end
            end)
            
            applyBtn.MouseLeave:Connect(function()
                TweenService:Create(applyBtn, getAnimInfo(), {
                    Size = UDim2.new(0, 70, 0, 36)
                }):Play()
            end)
            
            applyBtn.MouseButton1Click:Connect(function()
                switchTheme(theme.Name)
                
                -- Update all apply buttons
                for _, card in ipairs(scrollFrame:GetChildren()) do
                    if card:IsA("Frame") and card:FindFirstChild("Frame") then
                        local row = card:FindFirstChild("Frame")
                        if row and row:FindFirstChild("TextButton") then
                            local btn = row:FindFirstChild("TextButton")
                            if btn.Text:find("Active") then
                                btn.Text = "Apply"
                                btn.BackgroundColor3 = colors.accent
                            end
                        end
                    end
                end
                
                applyBtn.Text = "‚úď Active"
                applyBtn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
            end)
        end
    end
    
    tabContents[i] = contentContainer
    tabButtonsList[i] = tabButton
    
    -- Tab Button Interactions
    tabButton.MouseEnter:Connect(function()
        if not contentContainer.Visible and settings.animations then
            TweenService:Create(tabButton, getAnimInfo(), {
                BackgroundColor3 = colors.buttonHover
            }):Play()
        end
    end)
    
    tabButton.MouseLeave:Connect(function()
        if not contentContainer.Visible and settings.animations then
            TweenService:Create(tabButton, getAnimInfo(), {
                BackgroundColor3 = colors.tabInactive
            }):Play()
        end
    end)
    
    tabButton.MouseButton1Click:Connect(function()
        for _, c in ipairs(tabContents) do c.Visible = false end
        contentContainer.Visible = true
        
        for _, btn in ipairs(tabButtonsList) do
            if btn ~= tabButton then
                if settings.animations then
                    TweenService:Create(btn, getAnimInfo(), {
                        BackgroundColor3 = colors.tabInactive,
                        TextColor3 = colors.text
                    }):Play()
                else
                    btn.BackgroundColor3 = colors.tabInactive
                    btn.TextColor3 = colors.text
                end
            end
        end
        
        if settings.animations then
            TweenService:Create(tabButton, getAnimInfo(), {
                BackgroundColor3 = colors.tabActive,
                TextColor3 = colors.textActive
            }):Play()
        else
            tabButton.BackgroundColor3 = colors.tabActive
            tabButton.TextColor3 = colors.textActive
        end
    end)
end

