    local applyTheme
    local themeCards = {}

    applyTheme = function(name)
        currentTheme = name
        C = colorSchemes[name]

        for _, entry in ipairs(themeRegistry) do
            local obj = entry.obj
            local prop = entry.prop
            local key  = entry.key
            if obj and obj.Parent then
                local val
                if type(key) == "function" then val = key(C)
                else val = C[key] end
                if val then pcall(function() obj[prop] = val end) end
            end
        end

        for i, btn in ipairs(tabBtns) do
            if i == activeTab then
                btn.BackgroundColor3 = C.accent; btn.TextColor3 = Color3.new(1,1,1)
            else
                btn.BackgroundColor3 = C.elevated; btn.TextColor3 = C.textDim
            end
        end

        fovCircle.Color = safeColor(C.accent, Color3.fromRGB(100,160,255))
        watermarkFrame.BackgroundColor3 = C.surface
        wmStroke.Color = C.accent
        wmText.TextColor3 = C.text

