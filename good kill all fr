        local toggleTrack = Instance.new("Frame", miniToggle)
        toggleTrack.Size = UDim2.new(0, 22, 0, 10); toggleTrack.Position = UDim2.new(1, -26, 0.5, -5)
        toggleTrack.BackgroundColor3 = theme.accent; toggleTrack.BorderSizePixel = 0
        Instance.new("UICorner", toggleTrack).CornerRadius = UDim.new(1, 0)
        local tKnob = Instance.new("Frame", toggleTrack)
        tKnob.Size = UDim2.new(0, 8, 0, 8); tKnob.Position = UDim2.new(0, 13, 0.5, -4)
        tKnob.BackgroundColor3 = Color3.new(1,1,1); tKnob.BorderSizePixel = 0
        Instance.new("UICorner", tKnob).CornerRadius = UDim.new(1, 0)

        -- Mini slider
        local miniSlider = Instance.new("Frame", miniContent)
        miniSlider.Size = UDim2.new(1, -8, 0, 16); miniSlider.Position = UDim2.new(0, 4, 0, 30)
        miniSlider.BackgroundColor3 = theme.elevated; miniSlider.BorderSizePixel = 0
        Instance.new("UICorner", miniSlider).CornerRadius = UDim.new(0, 5)
        local sliderTrack = Instance.new("Frame", miniSlider)
        sliderTrack.Size = UDim2.new(1, -8, 0, 3); sliderTrack.Position = UDim2.new(0, 4, 0.5, -1)
        sliderTrack.BackgroundColor3 = theme.card; sliderTrack.BorderSizePixel = 0
        Instance.new("UICorner", sliderTrack).CornerRadius = UDim.new(1, 0)
        local sliderFill = Instance.new("Frame", sliderTrack)
        sliderFill.Size = UDim2.new(0.65, 0, 1, 0); sliderFill.BackgroundColor3 = theme.accent; sliderFill.BorderSizePixel = 0
        Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

        -- Color swatches row
        local swatchRow = Instance.new("Frame", miniContent)
        swatchRow.Size = UDim2.new(1, -8, 0, 10); swatchRow.Position = UDim2.new(0, 4, 0, 52)
        swatchRow.BackgroundTransparency = 1
        local swLayout2 = Instance.new("UIListLayout", swatchRow)
        swLayout2.FillDirection = Enum.FillDirection.Horizontal; swLayout2.Padding = UDim.new(0, 3)
        for _, col in ipairs({ theme.background, theme.accent, theme.success, theme.warning, theme.danger }) do
            local sw = Instance.new("Frame", swatchRow)
            sw.Size = UDim2.new(0, 10, 0, 10); sw.BackgroundColor3 = col; sw.BorderSizePixel = 0
            Instance.new("UICorner", sw).CornerRadius = UDim.new(0, 3)
        end

        -- Description label
        local descLbl = Instance.new("TextLabel", card)
        descLbl.Size = UDim2.new(0.65, 0, 0, 14); descLbl.Position = UDim2.new(0, 4, 1, -18)
        descLbl.Text = theme.description or ""; descLbl.Font = Enum.Font.Gotham; descLbl.TextSize = 9
        descLbl.TextColor3 = theme.textDim; descLbl.TextXAlignment = Enum.TextXAlignment.Left; descLbl.BackgroundTransparency = 1

        -- Apply button
        local applyBtn = Instance.new("TextButton", card)
        applyBtn.Size = UDim2.new(0, 70, 0, 20); applyBtn.Position = UDim2.new(1, -74, 1, -24)
        applyBtn.Text = currentTheme == name and "✓ Active" or "Apply"
        applyBtn.Font = Enum.Font.GothamBold; applyBtn.TextSize = 10
        applyBtn.BackgroundColor3 = theme.accent; applyBtn.BackgroundTransparency = currentTheme == name and 0 or 0.5
        applyBtn.TextColor3 = Color3.new(1,1,1)
        applyBtn.BorderSizePixel = 0; applyBtn.AutoButtonColor = false
        Instance.new("UICorner", applyBtn).CornerRadius = UDim.new(0, 6)

        applyBtn.MouseButton1Click:Connect(function()
            applyTheme(name)
        end)

        -- Also clickable on whole card
        local hitCard = Instance.new("TextButton", card)
        hitCard.Size = UDim2.new(1, 0, 1, 0); hitCard.BackgroundTransparency = 1
        hitCard.Text = ""; hitCard.ZIndex = 2
        hitCard.MouseButton1Click:Connect(function()
            applyTheme(name)
        end)
        -- Bring apply button above hitbox
        applyBtn.ZIndex = 3

        themeCards[name] = { stroke = cs, applyLbl = applyBtn, card = card }
        return card
    end

    -- Build all theme cards
    for _, name in ipairs(themeOrder) do
        if name ~= "Custom" then
            buildThemeCard(p, name)
        end
    end

    -- ── Custom Theme Editor ────────────────────────────────
    sectionLabel(p, "Custom Theme Editor")

    local customEditorCard = Instance.new("Frame", p)
    customEditorCard.Size = UDim2.new(1, 0, 0, 48); customEditorCard.BackgroundColor3 = C.elevated; customEditorCard.BorderSizePixel = 0
    Instance.new("UICorner", customEditorCard).CornerRadius = UDim.new(0, 12)
    reg(customEditorCard, "BackgroundColor3", "elevated")
    local customEditorLbl = Instance.new("TextLabel", customEditorCard)
    customEditorLbl.Size = UDim2.new(1, -20, 1, 0); customEditorLbl.Position = UDim2.new(0, 12, 0, 0)
    customEditorLbl.Text = "Customize individual colors for the Custom theme, then apply it."
    customEditorLbl.Font = Enum.Font.Gotham; customEditorLbl.TextSize = 11; customEditorLbl.TextColor3 = C.textDim
    customEditorLbl.TextXAlignment = Enum.TextXAlignment.Left; customEditorLbl.TextWrapped = true; customEditorLbl.BackgroundTransparency = 1
    reg(customEditorLbl, "TextColor3", "textDim")

    -- Custom color editors for major properties
    local customColorDefs = {
        { label = "Background",   key = "background" },
        { label = "Surface",      key = "surface" },
        { label = "Elevated",     key = "elevated" },
        { label = "Card",         key = "card" },
        { label = "Accent Color", key = "accent" },
        { label = "Text",         key = "text" },
        { label = "Text Dim",     key = "textDim" },
        { label = "Border",       key = "border" },
        { label = "Success",      key = "success" },
        { label = "Warning",      key = "warning" },
        { label = "Danger",       key = "danger" },
    }

    for _, def in ipairs(customColorDefs) do
        makeColorPicker(p, "Custom " .. def.label, customTheme[def.key], function(v)
            customTheme[def.key] = v
            colorSchemes["Custom"] = customTheme
            -- Rebuild preview swatches
            customTheme.preview = { customTheme.background, customTheme.accent, customTheme.success, customTheme.danger }
            -- If currently using custom, live-update
            if currentTheme == "Custom" then
                applyTheme("Custom")
            end
        end)
    end

    -- Build custom card last (after editor)
    buildThemeCard(p, "Custom")

    makeButton(p, "Apply Custom Theme", function()
        applyTheme("Custom")
    end)
end

