-- SERVER HOP — with optional auto re-execute
-- ══════════════════════════════════════════════════════════════
local function reExecuteScript()
    if not serverHopSettings.autoReExecute then return end
    local url = serverHopSettings.reExecuteURL
    if url and url ~= "" then
        -- If a URL is set, use loadstring to re-execute
        task.delay(3, function()
            pcall(function()
                local src = game:HttpGet(url)
                loadstring(src)()
            end)
        end)
    else
        -- Try to re-run the current script via syn.run_script or equivalent
        task.delay(3, function()
            pcall(function()
                if syn and syn.run_script then
                    -- Synapse method
                elseif SCRIPT_SOURCE then
                    loadstring(SCRIPT_SOURCE)()
                end
            end)
        end)
    end
end

-- Listen for teleport to re-execute
TeleportService.LocalPlayerArrivedFromTeleport:Connect(function()
    reExecuteScript()
end)

local function serverHop()
    notify("Server Hop", "Finding a new server...", "info", 3)
    task.spawn(function()
        local placeId = game.PlaceId
        local currentJobId = game.JobId
        local found = false

        pcall(function()
            local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
            local res = game:HttpGet(url)
            local data = HttpService:JSONDecode(res)
            if data and data.data then
                for _, server in ipairs(data.data) do
                    if server.id ~= currentJobId and server.playing < server.maxPlayers then
                        if serverHopSettings.autoReExecute then
                            notify("Server Hop", "Re-execute enabled — will reload script on join", "info", 3)
                        end
                        TeleportService:TeleportToPlaceInstance(placeId, server.id, player)
                        found = true
                        break
                    end
                end
            end
        end)

        if not found then
            pcall(function()
                TeleportService:Teleport(placeId, player)
            end)
        end
    end)
end

