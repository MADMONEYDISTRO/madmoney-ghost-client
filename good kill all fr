UserInputService.InputBegan:Connect(function(inp, gpe)
    if inp.UserInputType == Enum.UserInputType.MouseButton3 then
        -- Find the player currently under crosshair or aimed at
        local targetUnderCursor = nil

        -- First check if we have an active target
        if currentTarget and currentTarget.Parent then
            targetUnderCursor = currentTarget
        else
            -- Try to find nearest player to crosshair
            targetUnderCursor = getBestTarget()
        end

        if targetUnderCursor and targetUnderCursor ~= player then
            local added = toggleIgnore(targetUnderCursor)
            if added then
                notify("Ignore List", targetUnderCursor.Name .. " is now ignored (ESP/Aim/Trigger)", "warning", 3)
                -- Clear target if it was the ignored one
                if currentTarget == targetUnderCursor then
                    currentTarget = nil
                    aimlockSettings._velocityHistory = {}
                end
            else
                notify("Ignore List", targetUnderCursor.Name .. " removed from ignore list", "info", 2)
            end
        else
            notify("Ignore List", "No player to ignore near crosshair", "info", 1.5)
        end
    end
end)

-- ══════════════════════════════════════════════════════════════
-- TRIGGERBOT
-- ══════════════════════════════════════════════════════════════
local function getMouseTarget()
    local vp = Camera.ViewportSize
    local cx = vp.X / 2
    local cy = vp.Y / 2
    local unitRay = Camera:ScreenPointToRay(cx, cy)
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local exclude = {}
    if player.Character then table.insert(exclude, player.Character) end
    rp.FilterDescendantsInstances = exclude

    local range = triggerbotSettings.range
    if range > 0 then
        local mouseLoc = UserInputService:GetMouseLocation()
        local center = Vector2.new(cx, cy)
        local distFromCenter = (mouseLoc - center).Magnitude
        if distFromCenter > range then return nil end
    end

    local res = workspace:Raycast(unitRay.Origin, unitRay.Direction * 5000, rp)
    if not res then return nil end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and not isIgnored(p) then
            if res.Instance:IsDescendantOf(p.Character) then
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    if triggerbotSettings.teamCheck and isTeammate(p) then return nil end
                    return p
                end
            end
        end
    end
    return nil
end

RunService.RenderStepped:Connect(function()
    if not triggerbotSettings.enabled or triggerbotSettings._cooldown then return end
    local t = getMouseTarget()
    if t then
        triggerbotSettings._cooldown = true
        task.delay(triggerbotSettings.delay, function()
            if mouse1click then pcall(mouse1click) end
            triggerbotSettings._cooldown = false
        end)
    end
end)

-- ══════════════════════════════════════════════════════════════
-- ESP SYSTEM
-- ══════════════════════════════════════════════════════════════
local SKELETON_PAIRS = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
}

local function safeColor(c, fallback)
    if not c then return fallback or Color3.fromRGB(255, 255, 255) end
    local r, g, b = c.R, c.G, c.B
    if r < 0.02 and g < 0.02 and b < 0.02 then
        return fallback or Color3.fromRGB(255, 255, 255)
    end
    return c
end

local function cleanESP(p)
    local e = espObjects[p]
    if not e then return end
    for k, d in pairs(e) do
        if k ~= "player" then
            if type(d) == "table" then
                for _, line in ipairs(d) do pcall(function() if line and line.Remove then line:Remove() end end) end
            else
                pcall(function() if d and d.Remove then d:Remove() end end)
            end
        end
    end
    espObjects[p] = nil
end

local function makeDrawing(kind, props)
    local ok, d = pcall(function() return Drawing.new(kind) end)
    if not ok then return nil end
    for k, v in pairs(props) do
        pcall(function() d[k] = v end)
    end
    return d
end

local function buildESP(p)
    cleanESP(p)
    local e = { player = p }
    local boxCol     = safeColor(espSettings.boxColor,      Color3.fromRGB(255,255,255))
    local nameCol    = safeColor(espSettings.nameColor,     Color3.fromRGB(255,255,255))
    local tracerCol  = safeColor(espSettings.tracerColor,   Color3.fromRGB(0,200,255))
    local skelCol    = safeColor(espSettings.skeletonColor, Color3.fromRGB(255,150,0))
    local hpCol      = safeColor(espSettings.healthBarColor,Color3.fromRGB(50,220,80))

    if espSettings.boxes then
        e.boxOutline = makeDrawing("Square", { Thickness=4, Filled=false, Color=Color3.new(0,0,0), Visible=false, ZIndex=1 })
        e.box        = makeDrawing("Square", { Thickness=2, Filled=false, Color=boxCol, Visible=false, ZIndex=2 })
    end
    if espSettings.names then
        e.nameOut = makeDrawing("Text", { Text=p.Name, Size=14, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Font=2, Color=Color3.fromRGB(0,0,0), Visible=false, ZIndex=2 })
        e.name    = makeDrawing("Text", { Text=p.Name, Size=14, Center=true, Outline=false, Font=2, Color=nameCol, Visible=false, ZIndex=3 })
    end
    if espSettings.distance then
        e.dist = makeDrawing("Text", { Size=12, Center=true, Outline=true, OutlineColor=Color3.new(0,0,0), Font=2, Color=nameCol, Visible=false, ZIndex=3 })
    end
    if espSettings.healthBars then
        e.hpBg  = makeDrawing("Square", { Thickness=0, Filled=true, Color=Color3.fromRGB(20,20,20), Visible=false, ZIndex=1 })
        e.hpFg  = makeDrawing("Square", { Thickness=0, Filled=true, Color=hpCol, Visible=false, ZIndex=2 })
        e.hpBar = makeDrawing("Square", { Thickness=1, Filled=false, Color=Color3.fromRGB(0,0,0), Visible=false, ZIndex=3 })
    end
    if espSettings.tracers then
        e.tracerOut = makeDrawing("Line", { Thickness=3, Color=Color3.new(0,0,0), Visible=false, ZIndex=1 })
        e.tracer    = makeDrawing("Line", { Thickness=1.5, Color=tracerCol, Visible=false, ZIndex=2 })
    end
    if espSettings.skeletons then
        e.skeleton = {}
        for _ = 1, #SKELETON_PAIRS do
            table.insert(e.skeleton, makeDrawing("Line", { Thickness=1.5, Color=skelCol, Visible=false, ZIndex=2 }))
        end
    end
    espObjects[p] = e
end

local function hideESP(e)
    for k, d in pairs(e) do
        if k ~= "player" then
            if type(d) == "table" then
                for _, l in ipairs(d) do pcall(function() l.Visible = false end) end
            else
                pcall(function() d.Visible = false end)
            end
        end
    end
end

local function getHealthColor(pct)
    if pct > 0.6 then return safeColor(espSettings.healthBarColor, Color3.fromRGB(50,220,80))
    elseif pct > 0.3 then return Color3.fromRGB(255, 200, 50)
    else return Color3.fromRGB(255, 70, 70) end
end

local function updateESP()
    for p, e in pairs(espObjects) do
        if not p or not p.Parent then cleanESP(p); continue end
        -- Don't render ignored players
        if isIgnored(p) then hideESP(e); continue end
        local ch = p.Character
        if not (ch and ch:FindFirstChild("HumanoidRootPart") and ch:FindFirstChildOfClass("Humanoid")) then
            hideESP(e); continue
        end
        local hum  = ch.Humanoid
        local root = ch.HumanoidRootPart
        if hum.Health <= 0 then hideESP(e); continue end

        if espSettings.teamCheck then
            local sameTeam = false
            pcall(function()
                if player.Team and p.Team then
                    sameTeam = (p.Team == player.Team)
                end
            end)
            if sameTeam then hideESP(e); continue end
        end

        local dist = (root.Position - Camera.CFrame.Position).Magnitude
        if dist > espSettings.maxDistance then hideESP(e); continue end

        local headPart = ch:FindFirstChild("Head")
        local headPos  = headPart and headPart.Position or (root.Position + Vector3.new(0, 2.5, 0))
        local feetPos  = root.Position - Vector3.new(0, 3, 0)
        local headSP, headVis = Camera:WorldToViewportPoint(headPos)
        local feetSP, feetVis = Camera:WorldToViewportPoint(feetPos)
        if not (headVis or feetVis) then hideESP(e); continue end

        local h = math.abs(headSP.Y - feetSP.Y)
        if h < 2 then hideESP(e); continue end
        local w = h * 0.55
        local cx = headSP.X
        local ty = headSP.Y

        local boxCol  = safeColor(espSettings.boxColor,  Color3.fromRGB(255,255,255))
        local nameCol = safeColor(espSettings.nameColor, Color3.fromRGB(255,255,255))

        if e.box then
            local boxPos  = Vector2.new(cx - w/2, ty)
            local boxSize = Vector2.new(w, h)
            if e.boxOutline then
                e.boxOutline.Size = boxSize + Vector2.new(2, 2)
                e.boxOutline.Position = boxPos - Vector2.new(1, 1)
                e.boxOutline.Color = Color3.fromRGB(0,0,0)
                e.boxOutline.Visible = espSettings.enabled
            end
            e.box.Size = boxSize
            e.box.Position = boxPos
            e.box.Color = boxCol
            e.box.Visible = espSettings.enabled
        end
        if e.name then
            local np = Vector2.new(cx, ty - 18)
            if e.nameOut then
                e.nameOut.Position = np
                e.nameOut.Visible = espSettings.names and espSettings.enabled
            end
            e.name.Position = np
            e.name.Color = nameCol
            e.name.Visible = espSettings.names and espSettings.enabled
        end
        if e.dist then
            e.dist.Text = math.floor(dist) .. "m"
            e.dist.Position = Vector2.new(cx, ty + h + 6)
            e.dist.Color = nameCol
            e.dist.Visible = espSettings.distance and espSettings.enabled
        end
        if e.hpFg then
            local pct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
            local bx = cx - w/2 - 7; local bw = 4
            if e.hpBg then
                e.hpBg.Size = Vector2.new(bw, h + 2)
                e.hpBg.Position = Vector2.new(bx, ty - 1)
                e.hpBg.Color = Color3.fromRGB(20,20,20)
                e.hpBg.Visible = espSettings.healthBars and espSettings.enabled
            end
            e.hpFg.Size = Vector2.new(bw, math.max(h * pct, 1))
            e.hpFg.Position = Vector2.new(bx, ty + h * (1 - pct))
            e.hpFg.Color = getHealthColor(pct)
            e.hpFg.Visible = espSettings.healthBars and espSettings.enabled
            if e.hpBar then
                e.hpBar.Size = Vector2.new(bw + 2, h + 4)
                e.hpBar.Position = Vector2.new(bx - 1, ty - 2)
                e.hpBar.Color = Color3.fromRGB(0,0,0)
                e.hpBar.Visible = espSettings.healthBars and espSettings.enabled
            end
        end
        if e.tracer then
            local vp = Camera.ViewportSize
            local origin = Vector2.new(vp.X / 2, vp.Y / 2)
            local target = Vector2.new(feetSP.X, feetSP.Y)
            if e.tracerOut then
                e.tracerOut.From = origin; e.tracerOut.To = target
                e.tracerOut.Color = Color3.fromRGB(0,0,0)
                e.tracerOut.Visible = espSettings.tracers and espSettings.enabled
            end
            e.tracer.From = origin; e.tracer.To = target
            e.tracer.Color = safeColor(espSettings.tracerColor, Color3.fromRGB(0,200,255))
            e.tracer.Visible = espSettings.tracers and espSettings.enabled
        end
        if e.skeleton then
            for i, pair in ipairs(SKELETON_PAIRS) do
                local p1 = ch:FindFirstChild(pair[1]); local p2 = ch:FindFirstChild(pair[2])
                local line = e.skeleton[i]
                if p1 and p2 and line then
                    local s1, v1 = Camera:WorldToViewportPoint(p1.Position)
                    local s2, v2 = Camera:WorldToViewportPoint(p2.Position)
                    if v1 and v2 then
                        line.From = Vector2.new(s1.X, s1.Y); line.To = Vector2.new(s2.X, s2.Y)
                        line.Color = safeColor(espSettings.skeletonColor, Color3.fromRGB(255,150,0))
                        line.Visible = espSettings.skeletons and espSettings.enabled
                    else line.Visible = false end
                elseif line then line.Visible = false end
            end
        end
    end
end

RunService.RenderStepped:Connect(function()
    if espSettings.enabled then updateESP() end
end)

local function connectCharacterESP(p)
    p.CharacterAdded:Connect(function()
        task.wait(0.5)
        if espSettings.enabled then buildESP(p) end
    end)
    p.CharacterRemoving:Connect(function()
        task.wait(0.1)
        if espObjects[p] then hideESP(espObjects[p]) end
    end)
end

Players.PlayerAdded:Connect(function(p)
    connectCharacterESP(p)
    if espSettings.enabled then task.wait(1); buildESP(p) end
end)
Players.PlayerRemoving:Connect(cleanESP)
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= player then connectCharacterESP(p) end
end

-- ══════════════════════════════════════════════════════════════
-- CROSSHAIR
-- ══════════════════════════════════════════════════════════════
local function rebuildCrosshair()
    for _, d in pairs(crosshairLines) do
        pcall(function() if d and d.Remove then d:Remove() end end)
    end
    crosshairLines = {}
    for _, k in ipairs({"top","bottom","left","right"}) do
        crosshairLines[k] = Drawing.new("Line")
        crosshairLines[k].Thickness = crosshairSettings.thickness
        crosshairLines[k].Color     = crosshairSettings.color
        crosshairLines[k].Visible   = false
        crosshairLines[k].ZIndex    = 999
    end
end

RunService.RenderStepped:Connect(function()
    if not crosshairLines.top then return end
    local vp = Camera.ViewportSize
    local cx, cy = vp.X / 2, vp.Y / 2
    local s   = crosshairSettings.size
    local g   = crosshairSettings.gap
    local col = (crosshairSettings.dynamicColor and currentTarget) and C.danger or crosshairSettings.color
    crosshairLines.top.From    = Vector2.new(cx, cy - g);     crosshairLines.top.To    = Vector2.new(cx, cy - g - s)
    crosshairLines.bottom.From = Vector2.new(cx, cy + g);     crosshairLines.bottom.To = Vector2.new(cx, cy + g + s)
    crosshairLines.left.From   = Vector2.new(cx - g, cy);     crosshairLines.left.To   = Vector2.new(cx - g - s, cy)
    crosshairLines.right.From  = Vector2.new(cx + g, cy);     crosshairLines.right.To  = Vector2.new(cx + g + s, cy)
    for _, d in pairs(crosshairLines) do
