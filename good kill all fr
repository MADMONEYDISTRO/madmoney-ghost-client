-- EXECUTOR DETECTION
-- ══════════════════════════════════════════════════════════════
local function detectExecutor()
    local env = (getgenv and getgenv()) or {}
    local executorList = {
        { name = "Synapse X",   check = function() return env.syn or env.is_synapse_function end },
        { name = "Script-Ware", check = function() return env.isscriptware or env.ScriptWare end },
        { name = "KRNL",        check = function() return env.KRNL_LOADED end },
        { name = "Fluxus",      check = function() return env.fluxus or env.isfluxus end },
        { name = "Solara",      check = function() return env.solara or env.Solara end },
        { name = "Wave",        check = function() return env.iswave end },
        { name = "Volt",        check = function() return env.volt or env.Volt end },
        { name = "Hydrogen",    check = function() return env.hydrogen or env.Hydrogen end },
        { name = "Vega X",      check = function() return env.vega or env.Vega or env.VegaX end },
        { name = "Delta",       check = function() return env.delta or env.Delta end },
        { name = "Codex",       check = function() return env.codex or env.Codex end },
        { name = "Velocity",    check = function() return env.velocity or env.Velocity end },
    }
    local s1, execInfo = pcall(identifyexecutor)
    if s1 and execInfo then
        local info = tostring(execInfo)
        for _, e in ipairs(executorList) do
            if info:lower():find(e.name:lower(), 1, true) then return e.name end
        end
    end
    local s2, execName = pcall(getexecutorname)
    if s2 and execName then
        for _, e in ipairs(executorList) do
            if tostring(execName):lower():find(e.name:lower(), 1, true) then return e.name end
        end
        if tostring(execName) ~= "" then return tostring(execName) end
    end
    for _, e in ipairs(executorList) do
        local ok, result = pcall(e.check)
        if ok and result then return e.name end
    end
    return "Unknown"
end

