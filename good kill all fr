local function isBot(p)
    if not p.Character then return false end
    local name = p.Name
    for _, pat in ipairs(aimlockSettings.botNamePatterns) do
        if name:find(pat, 1, true) then return true end
    end
    local age = 0
    pcall(function() age = p.AccountAge end)
    if age == 0 then return true end
    return false
end

-- ══════════════════════════════════════════════════════════════
-- AIMLOCK
-- ══════════════════════════════════════════════════════════════
local function pushVelocityHistory(vel)
    local h = aimlockSettings._velocityHistory
    table.insert(h, vel)
    if #h > aimlockSettings._historyMax then table.remove(h, 1) end
end

local function getSmoothedVelocity()
    local h = aimlockSettings._velocityHistory
    if #h == 0 then return Vector3.zero end
    local sum, totalWeight = Vector3.zero, 0
    for i, v in ipairs(h) do
        sum = sum + v * i; totalWeight = totalWeight + i
    end
    return sum / totalWeight
end

local function isTeammate(p)
    if not aimlockSettings.teamCheck then return false end
    local ok, result = pcall(function()
        if player.Team and p.Team then
            return p.Team == player.Team
        end
        return false
    end)
    return ok and result
end

local function isTargetValid(t)
    if not t or t == player then return false end
    if isIgnored(t) then return false end
    if not t.Character then return false end
    local hum = t.Character:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if isTeammate(t) then return false end
    local targetIsBot = isBot(t)
    if targetIsBot and not aimlockSettings.targetBots then return false end
    return true
end

local function wallCheck(pos)
    if not aimlockSettings.wallCheck then return true end
    local origin = Camera.CFrame.Position
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local exclude = { Camera }
    if player.Character then table.insert(exclude, player.Character) end
    rp.FilterDescendantsInstances = exclude
    local res = workspace:Raycast(origin, (pos - origin) * 0.99, rp)
    if not res then return true end
    if currentTarget and currentTarget.Character then
        return res.Instance:IsDescendantOf(currentTarget.Character)
    end
    return false
end

local function getTargetPriority(p, screenDist, dist3D)
    local mode = aimlockSettings.priorityMode
    if mode == "Closest to Crosshair" then return screenDist
    elseif mode == "Lowest HP" then
        local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
        return hum and hum.Health or math.huge
    elseif mode == "Closest Distance" then return dist3D end
    return screenDist
end

local function getBestTarget()
    local best, bestScore = nil, math.huge
    local mouse = UserInputService:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if isTargetValid(p) then
            local ch   = p.Character
            local part = ch:FindFirstChild(aimlockSettings.targetPart) or ch:FindFirstChild("HumanoidRootPart")
            if part then
                local dist3D = (part.Position - Camera.CFrame.Position).Magnitude
                if dist3D <= aimlockSettings.maxDistance then
                    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local screenDist = (Vector2.new(sp.X, sp.Y) - mouse).Magnitude
                        if screenDist <= aimlockSettings.fov and screenDist >= aimlockSettings.minFOV then
                            local passWall = (not aimlockSettings.visibleOnly) or wallCheck(part.Position)
                            if passWall then
                                local score = getTargetPriority(p, screenDist, dist3D)
                                if score < bestScore then
                                    bestScore = score; best = p
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return best
end

local function doAim(t)
    if not t or not t.Character then return end
    local part = t.Character:FindFirstChild(aimlockSettings.targetPart) or t.Character:FindFirstChild("HumanoidRootPart")
    if not part then return end
    local vel = part.AssemblyLinearVelocity
    pushVelocityHistory(vel)
    local pos = part.Position
    pos = pos + Vector3.new(aimlockSettings.offsetX, aimlockSettings.offsetY, 0)
    if aimlockSettings.predictionEnabled then
        local smoothVel = getSmoothedVelocity()
        local dist = (pos - Camera.CFrame.Position).Magnitude
        local factor = aimlockSettings.predictionMultiplier * (1 + dist / 800)
        pos = pos + smoothVel * factor
    end
    local cur    = Camera.CFrame
    local target = CFrame.new(cur.Position, pos)
    local smooth = aimlockSettings.smoothness * aimlockSettings.magnetStrength
    smooth = math.clamp(smooth, 0.01, 1)
    Camera.CFrame = cur:Lerp(target, smooth)
end

local function startAimlock()
    if aimlockConn then aimlockConn:Disconnect() end
    aimlockConn = RunService.RenderStepped:Connect(function()
        if not aimlockSettings.enabled then return end
        if UserInputService:IsMouseButtonPressed(aimlockSettings.aimKey) then
            if not (aimlockSettings.stickTarget and currentTarget and isTargetValid(currentTarget)) then
                if not currentTarget or not isTargetValid(currentTarget) then
                    currentTarget = getBestTarget()
                end
            end
            if aimlockSettings.autoSwitch and (not currentTarget or not isTargetValid(currentTarget)) then
                currentTarget = getBestTarget()
            end
            if currentTarget then doAim(currentTarget) end
        else
            if not aimlockSettings.stickTarget then
                currentTarget = nil
                aimlockSettings._velocityHistory = {}
            end
        end
    end)
end

local function stopAimlock()
    if aimlockConn then aimlockConn:Disconnect(); aimlockConn = nil end
    currentTarget = nil
    aimlockSettings._velocityHistory = {}
end

