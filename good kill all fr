UserInputService.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end

    if inp.KeyCode == keybinds.toggleUI then
        mainFrame.Visible = not mainFrame.Visible
        if mainFrame.Visible then
            tween(mainFrame, { Size = UDim2.new(0, 760, 0, 560) }, 0.35, Enum.EasingStyle.Back)
        end
    elseif inp.KeyCode == keybinds.toggleAimlock then
        aimlockSettings.enabled = not aimlockSettings.enabled
        if aimlockSettings.enabled then startAimlock() else stopAimlock() end
        notify("Aimlock", aimlockSettings.enabled and "Enabled" or "Disabled", aimlockSettings.enabled and "success" or "info")
    elseif inp.KeyCode == keybinds.toggleTrigger then
        triggerbotSettings.enabled = not triggerbotSettings.enabled
        notify("Triggerbot", triggerbotSettings.enabled and "Enabled" or "Disabled", triggerbotSettings.enabled and "success" or "info")
    elseif inp.KeyCode == keybinds.toggleFreecam then
        freecamSettings.enabled = not freecamSettings.enabled
        setFreecam(freecamSettings.enabled)
        notify("Freecam", freecamSettings.enabled and "Enabled" or "Disabled", freecamSettings.enabled and "success" or "info")
    elseif inp.KeyCode == keybinds.panic then
        aimlockSettings.enabled       = false
        triggerbotSettings.enabled    = false
        espSettings.enabled           = false
        movementSettings.speedHack    = false
        movementSettings.flight       = false
        movementSettings.infiniteJump = false
        freecamSettings.enabled       = false
        stopAimlock(); setFlight(false); setInfJump(false); updateSpeed(); setFreecam(false)
        for pl in pairs(espObjects) do cleanESP(pl) end
        mainFrame.Visible = false
        notify("PANIC", "All features disabled immediately", "error", 4)
    end
end)

