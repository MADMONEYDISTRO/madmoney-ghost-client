-- FREECAM — Fixed mouse look + rebindable up/down keys
-- ══════════════════════════════════════════════════════════════
local freecamActive       = false
local freecamCF           = CFrame.new()
local freecamOrigCameraType = Enum.CameraType.Custom
local freecamOrigSubject    = nil
local freecamYaw   = 0
local freecamPitch = 0

local function setFreecam(on)
    if on then
        if freecamActive then return end
        freecamActive = true
        freecamOrigCameraType = Camera.CameraType
        freecamOrigSubject    = Camera.CameraSubject
        freecamCF   = Camera.CFrame
        -- Decompose current CFrame into yaw/pitch
        local rx, ry, rz = freecamCF:ToEulerAnglesYXZ()
        freecamPitch = rx
        freecamYaw   = ry
        Camera.CameraType = Enum.CameraType.Scriptable

        RunService:BindToRenderStep("FeatherFreecam", 300, function()
            if not freecamActive then
                RunService:UnbindFromRenderStep("FeatherFreecam")
                return
            end
            local spd  = freecamSettings.speed
            local pos  = freecamCF.Position
            local look = freecamCF.LookVector
            local right = freecamCF.RightVector
            local move = Vector3.zero

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + look end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - look end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - right end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + right end
            -- Rebindable up/down
            if UserInputService:IsKeyDown(keybinds.freecamUp)   then move = move + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(keybinds.freecamDown) then move = move - Vector3.new(0,1,0) end

            if move.Magnitude > 0 then
                pos = pos + move.Unit * (spd * 0.016)
            end

            freecamCF = CFrame.new(pos) * CFrame.fromEulerAnglesYXZ(freecamPitch, freecamYaw, 0)
            Camera.CFrame = freecamCF
            Camera.FieldOfView = freecamSettings.fov
        end)
    else
        freecamActive = false
        RunService:UnbindFromRenderStep("FeatherFreecam")
        Camera.CameraType = freecamOrigCameraType
        if freecamOrigSubject then
            Camera.CameraSubject = freecamOrigSubject
        end
        Camera.FieldOfView = 70
        notify("Freecam", "Disabled — camera restored", "info", 2)
    end
end

-- Freecam mouse look — Fixed: proper yaw/pitch decomposition
UserInputService.InputChanged:Connect(function(inp)
    if freecamActive and inp.UserInputType == Enum.UserInputType.MouseMovement then
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local sens = freecamSettings.sensitivity * 0.005
            freecamYaw   = freecamYaw   - inp.Delta.X * sens
            freecamPitch = math.clamp(freecamPitch - inp.Delta.Y * sens, -math.pi/2 + 0.01, math.pi/2 - 0.01)
        end
    end
end)

