    card.Parent           = notifHolder
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 14)

    local stroke = Instance.new("UIStroke", card)
    stroke.Color = kc; stroke.Thickness = 1.5; stroke.Transparency = 0.35

    local bar = Instance.new("Frame", card)
    bar.Size = UDim2.new(0, 3, 1, 0); bar.BackgroundColor3 = kc; bar.BorderSizePixel = 0
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 3)

    local icon = Instance.new("TextLabel", card)
    icon.Size = UDim2.new(0, 28, 0, 28); icon.Position = UDim2.new(0, 14, 0, 14)
    icon.Text = ki; icon.Font = Enum.Font.GothamBold; icon.TextSize = 16
    icon.TextColor3 = kc; icon.BackgroundTransparency = 1

    local tl = Instance.new("TextLabel", card)
    tl.Size = UDim2.new(1, -80, 0, 18); tl.Position = UDim2.new(0, 50, 0, 12)
    tl.Text = title; tl.Font = Enum.Font.GothamBold; tl.TextSize = 13
    tl.TextColor3 = C.text; tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.BackgroundTransparency = 1

    local bl = Instance.new("TextLabel", card)
    bl.Size = UDim2.new(1, -80, 0, 16); bl.Position = UDim2.new(0, 50, 0, 32)
    bl.Text = body; bl.Font = Enum.Font.Gotham; bl.TextSize = 11
    bl.TextColor3 = C.textDim; bl.TextXAlignment = Enum.TextXAlignment.Left
    bl.BackgroundTransparency = 1; bl.TextWrapped = true

    local close = Instance.new("TextButton", card)
    close.Size = UDim2.new(0, 22, 0, 22); close.Position = UDim2.new(1, -30, 0, 12)
    close.Text = "×"; close.Font = Enum.Font.GothamBold; close.TextSize = 16
    close.TextColor3 = C.textDim; close.BackgroundColor3 = C.elevated
    close.BorderSizePixel = 0; close.AutoButtonColor = false
    Instance.new("UICorner", close).CornerRadius = UDim.new(1, 0)

    tween(card, { Size = UDim2.new(1, 0, 0, 62) }, 0.3, Enum.EasingStyle.Back)

    local function dismiss()
        tween(card, { Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1 }, 0.25)
        tween(stroke, { Transparency = 1 }, 0.25)
        tween(tl, { TextTransparency = 1 }, 0.25)
        tween(bl, { TextTransparency = 1 }, 0.25)
        tween(icon, { TextTransparency = 1 }, 0.25)
        task.delay(0.3, function() if card and card.Parent then card:Destroy() end end)
    end
    task.delay(dur, dismiss)
    close.MouseButton1Click:Connect(dismiss)
end

