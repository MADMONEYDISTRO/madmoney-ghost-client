local activeTab = 1

local function switchTab(idx)
    if activeTab == idx then return end
    activeTab = idx
    for i, btn in ipairs(tabBtns) do
        if i == idx then
            tween(btn, { BackgroundColor3 = C.accent, TextColor3 = Color3.new(1,1,1) }, 0.2)
        else
            tween(btn, { BackgroundColor3 = C.elevated, TextColor3 = C.textDim }, 0.2)
        end
    end
    for i, page in ipairs(tabPages) do
        page.Visible = (i == idx)
    end
end

