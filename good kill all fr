-- IGNORE LIST (middle-click players to ignore all targeting/ESP)
-- ══════════════════════════════════════════════════════════════
local ignoreList = {} -- [player] = true

local function toggleIgnore(p)
    if not p or p == player then return end
    if ignoreList[p] then
        ignoreList[p] = nil
        return false -- removed from ignore
    else
        ignoreList[p] = true
        return true -- added to ignore
    end
end

local function isIgnored(p)
    return ignoreList[p] == true
end

