    dur = dur or uiSettings.notificationDuration
    local kindColors = { info = C.accent, success = C.success, warning = C.warning, error = C.danger }
    local kindIcons  = { info = "ℹ", success = "✓", warning = "⚠", error = "✕" }
    local kc = kindColors[kind] or C.accent
    local ki = kindIcons[kind] or "ℹ"

    local card = Instance.new("Frame")
